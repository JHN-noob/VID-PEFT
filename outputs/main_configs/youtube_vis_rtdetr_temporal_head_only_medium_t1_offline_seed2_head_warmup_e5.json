{
  "model_family": "rtdetr_temporal",
  "dataset": {
    "name": "youtube_vis",
    "num_classes": 40
  },
  "tuning_mode": "head_only",
  "budget": "medium",
  "seed": 2,
  "run_tag": "head_warmup_e5",
  "clip": {
    "length": 1,
    "causal": false,
    "target": "center"
  },
  "paths": {
    "youtube_vis_root": "data/VIS2021",
    "outputs_root": "outputs",
    "rtdetr_repo": "third_party/RT-DETR"
  },
  "head_replacement": {
    "enabled": true,
    "train": true,
    "num_classes": 40,
    "phase": "warmup",
    "reason": "Create a 40-class YouTube-VIS head-adapted checkpoint before PEFT."
  },
  "execution": {
    "dry_run": true,
    "epochs": 5,
    "notes": "Set dry_run=false after RT-DETR dependencies and checkpoint are available to run the actual head warmup before PEFT."
  },
  "rtdetr": {
    "variant": "rtdetrv2-s-r18vd",
    "checkpoint": "weights/rtdetrv2_r18vd_120e_coco_rerun_48.1.pth",
    "official_checkpoint_url": "https://github.com/lyuwenyu/storage/releases/download/v0.2/rtdetrv2_r18vd_120e_coco_rerun_48.1.pth",
    "generated_config": "outputs/rtdetr_configs/youtube_vis_rtdetr_temporal_head_only_medium_t1_offline_seed2_head_warmup_e5.yml",
    "dataset_export": {
      "train_manifest": "outputs/splits/youtube_vis_pilot_train.jsonl",
      "val_manifest": "outputs/splits/youtube_vis_pilot_dev.jsonl",
      "output_root": "outputs/rtdetr_datasets/youtube_vis_pilot",
      "image_mode": "hardlink"
    },
    "train_args": {
      "epochs": 5,
      "total_batch_size": 4,
      "num_workers": 0,
      "print_freq": 20,
      "use_amp": true,
      "use_ema": false,
      "sync_bn": false
    }
  }
}
