{
  "model_family": "yolo_temporal",
  "dataset": {
    "name": "youtube_vis",
    "num_classes": 40
  },
  "tuning_mode": "spatial_temporal_peft",
  "budget": "medium",
  "seed": 2,
  "clip": {
    "length": 5,
    "causal": false,
    "target": "center"
  },
  "paths": {
    "youtube_vis_root": "data/VIS2021",
    "outputs_root": "outputs",
    "ultralytics_repo": "third_party/ultralytics"
  },
  "head_replacement": {
    "enabled": true,
    "train": false,
    "num_classes": 40,
    "phase": "frozen_after_warmup",
    "reason": "Use the 40-class YouTube-VIS head warmup checkpoint, then freeze the head during PEFT."
  },
  "execution": {
    "dry_run": true,
    "epochs": 5,
    "notes": "Set dry_run=false after the head warmup checkpoint exists. T>1 uses target-frame clip batches."
  },
  "yolo": {
    "weights": "outputs/runs/youtube_vis_yolo_temporal_head_only_medium_t1_offline_seed2_head_warmup_e5/weights/best.pt",
    "base_weights": "yolov8m.pt",
    "head_warmup_checkpoint": "outputs/runs/youtube_vis_yolo_temporal_head_only_medium_t1_offline_seed2_head_warmup_e5/weights/best.pt",
    "adapter": {
      "feature_level": "P4",
      "layer_index": 18,
      "channels": 384,
      "adapter_dim": 32,
      "kernel_size": 3,
      "residual_scale": 0.1,
      "placement": "detect_pre_forward"
    },
    "clip_loader": {
      "enabled": true,
      "boundary": "clamp",
      "notes": "Clip loader flattens B clips to B*T images and keeps labels on target frames."
    },
    "train_args": {
      "data": "outputs/yolo_datasets/youtube_vis_pilot/data.yaml",
      "epochs": 5,
      "imgsz": 640,
      "batch": 1,
      "workers": 0,
      "freeze": 23,
      "plots": false,
      "val": true,
      "optimizer": "AdamW",
      "lr0": 0.0001,
      "lrf": 0.1,
      "warmup_epochs": 1.0,
      "warmup_bias_lr": 0.0001
    }
  },
  "run_tag": "main_stable_e5"
}
