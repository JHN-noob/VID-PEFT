{
  "model_family": "yolo_temporal",
  "dataset": {
    "name": "youtube_vis",
    "num_classes": 40
  },
  "tuning_mode": "spatial_only_full_ft",
  "budget": "medium",
  "seed": 0,
  "clip": {
    "length": 1,
    "causal": false,
    "target": "center"
  },
  "paths": {
    "youtube_vis_root": "data/VIS2021",
    "outputs_root": "outputs",
    "ultralytics_repo": "third_party/ultralytics"
  },
  "head_replacement": {
    "enabled": true,
    "train": true,
    "num_classes": 40,
    "phase": "spatial_only_full_ft_after_warmup",
    "reason": "Start from the 40-class YouTube-VIS head warmup checkpoint and unfreeze all parameters for a single-frame full fine-tuning baseline."
  },
  "execution": {
    "dry_run": true,
    "epochs": 1,
    "notes": "Set dry_run=false for single-frame spatial-only full fine-tuning."
  },
  "yolo": {
    "weights": "outputs/runs/youtube_vis_yolo_temporal_head_only_medium_t1_offline_seed0_head_warmup_e5/weights/best.pt",
    "base_weights": "yolov8m.pt",
    "head_warmup_checkpoint": "outputs/runs/youtube_vis_yolo_temporal_head_only_medium_t1_offline_seed0_head_warmup_e5/weights/best.pt",
    "clip_loader": {
      "enabled": false,
      "boundary": "clamp"
    },
    "train_args": {
      "data": "outputs/yolo_datasets/youtube_vis_pilot/data.yaml",
      "epochs": 1,
      "imgsz": 640,
      "batch": 1,
      "workers": 0,
      "plots": false,
      "val": true
    }
  }
}
